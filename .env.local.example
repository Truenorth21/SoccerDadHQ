# SoccerDadHQ environment variables
# Copy this file to .env.local and fill in your Supabase project values.
# The site runs with built-in seed data even if these are left blank —
# Supabase is only required for auth, persisting reviews/votes, and the newsletter.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public base URL (used for SEO canonical/OG tags). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://soccerdadhq.com

# Server-only (never exposed to the browser). Needed for the monthly ranking
# snapshot cron to write standings, and for any RLS-bypassing admin writes.
SUPABASE_SERVICE_ROLE_KEY=

# Protects the cron endpoint. Set this and Vercel Cron sends it as a Bearer token.
CRON_SECRET=

# Email delivery (Resend) — powers the welcome email and weekly Sideline digests.
# Leave blank to keep emails in no-op/demo mode. Get a key at resend.com.
RESEND_API_KEY=
# Verified sender. Must be on a domain you've verified in Resend.
EMAIL_FROM=The Sideline <sideline@soccerdadhq.com>

# Signs one-click unsubscribe links so they can't be forged. Any random string.
UNSUBSCRIBE_SECRET=

# Analytics (optional). Set one to enable; leave blank for none.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=          # e.g. soccerdadhq.com
NEXT_PUBLIC_GA_ID=                     # e.g. G-XXXXXXXXXX

# Google AdSense (optional). When set, unsold ad slots are filled by AdSense
# instead of a rotating self-promo.
NEXT_PUBLIC_ADSENSE_CLIENT=            # e.g. ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT=              # a responsive ad-unit slot ID

# Payment link for ad orders (optional, no Stripe integration needed).
# Paste a Stripe Payment Link / PayPal.me / Square invoice URL; a "Pay now"
# button then appears on the ad-order confirmation.
NEXT_PUBLIC_PAYMENT_LINK=
